@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">
    <style>
        body {
            background: linear-gradient(to right, #2193b0, #6dd5ed);
            min-height: 100vh;
        }
    </style>
    <div class="container d-flex justify-content-center align-items-center" style="min-height:70vh;">

        <div class="w-100">

            <!-- Title -->
            <div class="text-center mb-5 text-white">
                <h1>Welcome to Employee Management System</h1>
                <p>Manage your people easily</p>
            </div>

            <!-- Cards -->
            <div class="row justify-content-center">

                <!-- View -->
                <div class="col-md-3">
                    <div class="card shadow-lg p-4 mb-4 text-center border-0">
                        <h4>View Employees</h4>
                        <p>See all registered persons</p>
                        <a href="/Person/DisplayPersons" class="btn btn-primary">View List</a>
                    </div>
                </div>

                <!-- Add -->
                <div class="col-md-3">
                    <div class="card shadow-lg p-4 mb-4 text-center border-0">
                        <h4>Add Employee</h4>
                        <p>Add new person to system</p>
                        <a href="/Person/AddPerson" class="btn btn-success">Add Person</a>
                    </div>
                </div>

                <!-- Manage -->
                <div class="col-md-3">
                    <div class="card shadow-lg p-4 mb-4 text-center border-0">
                        <h4>Manage</h4>
                        <p>Edit or delete existing persons</p>
                        <a href="/Person/DisplayPersons" class="btn btn-warning">Manage</a>
                    </div>
                </div>

            </div>

        </div>

    </div>
