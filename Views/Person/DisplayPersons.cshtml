@model IEnumerable<MvcCoreTutorial.Models.Domain.Person>

<div class="container mt-2">
    <style>
        body {
            background: linear-gradient(to right, #2193b0, #6dd5ed);
            min-height: 100vh;
        }
    </style>

    <!-- Button aligned right -->
    <div class="d-flex justify-content-start">

        <div class="mt-2" style="width:50%">
            <div class="row">
                <h2>Employees</h2>
                <div class="col-md-4">
                    <a href="/Person/AddPerson" class="btn btn-secondary">Add Employee</a>
                    <a href="/Person/index" class="btn btn-secondary">Back</a>
                </div>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Age</th>
                            <th>Phone Number</th>
                            <th>Address</th>
                            <th>Action</th>
                        </tr>

                        @foreach (var person in Model)
                        {
                            <tr>
                                <td>
                                    @person.Name
                                </td>
                                <td>@person.Email</td>
                                <td>@person.Age</td>
                                <td>@person.PhoneNumber</td>
                                <td>@person.Address</td>
                                <td>
                                    <a class="btn btn-success" href="/Person/EditPerson?id=@person.Id">Edit</a>
                                    <a class="btn btn-danger" href="/Person/DeletePerson?id=@person.Id">Delete</a>
                                </td>
                               
                            </tr>
                        }
                    </thead>
                </table>
            </div>

        </div>
       </div>

</div>